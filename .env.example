# AI Provider Configuration

# Format: provider/model
# Valid providers: "openai" | "claude" | "gemini" | "open_router" | "deepseek" | "nvidia_nim" | "ollama" | "lmstudio" | "opencode"
# Examples:
# MODEL="openai/gpt-4o"
# MODEL="claude/claude-3-5-sonnet-20240620"
# MODEL="gemini/gemini-1.5-pro-latest"
# MODEL="open_router/anthropic/claude-3.5-sonnet"
# MODEL="deepseek/deepseek-coder"
# MODEL="ollama/llama3"
# MODEL="opencode"
# MODEL="open_router"

MODEL="opencode/minimax/minimax-m2.5:free"

# API Keys
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GOOGLE_API_KEY=""
OPENROUTER_API_KEY=""
DEEPSEEK_API_KEY=""
NVIDIA_NIM_API_KEY=""
OPENCODE_API_KEY=""

# Local Provider URLs (defaults are usually fine)
LM_STUDIO_BASE_URL="http://localhost:1234/v1"
LLAMACPP_BASE_URL="http://localhost:8080/v1"
OLLAMA_BASE_URL="http://localhost:11434"
